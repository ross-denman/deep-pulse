# ====================================
# Deep Ledger — Environment Template
# Copy this file to .env and fill in your values.
# ====================================

# --- Sovereign Identity (Ed25519) ---
# Generated by: python src/core/identity_generator.py
NODE_PRIVATE_KEY=
NODE_PUBLIC_KEY=
NODE_ID=

# --- LLM Provider ---
# Choose ONE provider. Set LLM_PROVIDER and the matching API key/base URL.
#
# Supported providers:
#   local       — Ollama, LM Studio, llama.cpp, or any local server
#   openai      — OpenAI API (GPT-4o, etc.)
#   anthropic   — Anthropic API (Claude, etc.)
#   openrouter  — OpenRouter (multi-model gateway)
#   custom      — Any OpenAI-compatible API endpoint
#
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434/v1

# Model selection — set to match your provider:
#
#   local       → llama3, mistral, deepseek-coder-v2, phi-3, gemma2, qwen2
#   openai      → gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-preview
#   anthropic   → claude-opus-4-20250514, claude-sonnet-4-20250514, claude-3-haiku-20240307
#   openrouter  → openrouter/auto, meta-llama/llama-3-70b, mistralai/mistral-large
#   custom      → (whatever your endpoint serves)
#
LLM_MODEL=llama3

# Cloud API keys (fill in ONLY the one you're using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Custom OpenAI-compatible endpoint (set LLM_PROVIDER=custom)
# LLM_BASE_URL=https://your-endpoint.example.com/v1
# LLM_API_KEY=

# --- Neo4j (Dual-Mode) ---
# Local Docker (default — for development):
NEO4J_URI=bolt://localhost:7687
# Aura Production (uncomment when ready — for the Always-On Global Brain):
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=deep-ledger-secret
