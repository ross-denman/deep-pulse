# ====================================
# Deep Pulse — Sovereign Outpost Boilerplate
# Copy this file to .env and fill in your keys.
# ====================================

# --- Sovereign Identity (Generated) ---
# Use 'python3 core/identity_generator.py' to populate these.
OUTPOST_KEY=
OUTPOST_PUBLIC_KEY=
OUTPOST_ID=

# --- Knowledge Graph (Edge) ---
KUZU_DB_PATH=harvest/kuzu_db

# --- Mesh Connectivity ---
# The URL of the Sovereign Notary for sync and training pulses.
NOTARY_URL=http://localhost:4110

# --- Search Engine (Brave) ---
# Required for autonomous scouting operations.
BRAVE_API_KEY=

# --- LLM Intelligence (Scouts) ---
# The logic layer for entity extraction and briefings. 
# Compatible with OpenAI, OpenRouter, or Local Ollama.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free

# --- Local Intelligence (Ollama) ---
# Uncomment to use air-gapped forensic models.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# --- Environment ---
PYTHONPATH=.
DEBUG=false
