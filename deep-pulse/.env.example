# --- Node Identity ---
# Run 'python3 src/pulse.py init' to generate these
NODE_ID=
NODE_PUBLIC_KEY=
NODE_PRIVATE_KEY=

# --- LLM Provider ---
# Choose ONE provider. Set LLM_PROVIDER and the matching API key/base URL.
#
# Supported providers:
#   local       — Ollama, LM Studio, llama.cpp, or any local server
#   openai      — OpenAI API (GPT-4o, etc.)
#   anthropic   — Anthropic API (Claude, etc.)
#   openrouter  — OpenRouter (multi-model gateway)
#   custom      — Any OpenAI-compatible API endpoint
#
LLM_PROVIDER=local

# Model selection — set to match your provider:
#   local       → llama3, mistral, deepseek-coder-v2, phi-3, gemma2, qwen2
#   openai      → gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-preview
#   anthropic   → claude-3-5-sonnet-20240620, claude-3-opus-20240229
#   openrouter  → openrouter/auto, meta-llama/llama-3-70b
#
LLM_MODEL=llama3
LLM_BASE_URL=http://localhost:11434/v1

# --- Adaptive RAG Cost Shield ---
# Tier 0 summarizing using a tiny local model
LOCAL_DISTILL_MODEL=qwen2-0.5B
LOCAL_DISTILL_URL=http://localhost:11434/v1
MAX_COST=2.00
MAX_TIME=300

# API Keys (Fill in ONLY the one you are using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Bridge Configuration ---
# Co-located Deep Ledger bridge ports
LEDGER_INFO_BRIDGE=http://localhost:4110
LEDGER_ALERT_BRIDGE=http://localhost:9110

# --- Discovery Services ---
BRAVE_API_KEY=

# --- Tor Stealth Proxy ---
USE_PROXY=True
PROXY_URL=http://127.0.0.1:8118
STRICT_PROXY=False
